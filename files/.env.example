# ══════════════════════════════════════════════════════════════════
# Trading Assistant — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to source control.
# ══════════════════════════════════════════════════════════════════

# ── Application ───────────────────────────────────────────────────
APP_NAME=TradingAssistant
ENVIRONMENT=development           # development | staging | production
DEBUG=false
SECRET_KEY=change-this-to-a-random-64-char-string
LOG_LEVEL=INFO

# CRITICAL SAFETY SWITCH — leave as "paper" until ready for live trading
EXECUTION_MODE=paper              # paper | live  (live requires ENVIRONMENT=production)

# ── Discord ───────────────────────────────────────────────────────
# Bot token from https://discord.com/developers/applications
DISCORD_BOT_TOKEN=your-discord-bot-token-here
# Right-click your server → Copy Server ID (Developer Mode must be enabled)
DISCORD_GUILD_ID=123456789012345678
# Right-click your target channel → Copy Channel ID
DISCORD_CHANNEL_ID=123456789012345678
DISCORD_INCLUDE_BOT_MESSAGES=false
DISCORD_HISTORICAL_BACKFILL_LIMIT=500
DISCORD_HISTORICAL_FETCH_DELAY_SECONDS=1.0

# ── Database (PostgreSQL) ──────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=trading_assistant
DB_USER=postgres
DB_PASSWORD=your-secure-database-password
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_ECHO_SQL=false

# ── Redis ─────────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_CELERY_DB=1

# ── Binance Futures ───────────────────────────────────────────────
# Get from https://www.binance.com/en/my/settings/api-management
BINANCE_API_KEY=your-binance-api-key
BINANCE_API_SECRET=your-binance-api-secret
BINANCE_ENVIRONMENT=testnet       # testnet | live
BINANCE_MAX_NOTIONAL_PER_TRADE_USD=100.0
BINANCE_DEFAULT_LEVERAGE=1
BINANCE_ALLOW_SIGNAL_LEVERAGE=false

# ── Alpaca ────────────────────────────────────────────────────────
# Get from https://alpaca.markets
ALPACA_API_KEY=your-alpaca-api-key
ALPACA_API_SECRET=your-alpaca-api-secret
ALPACA_ENVIRONMENT=paper          # paper | live
ALPACA_MAX_NOTIONAL_PER_TRADE_USD=500.0
ALPACA_FRACTIONAL_SHARES_ENABLED=false

# ── LLM (fallback parser) ─────────────────────────────────────────
LLM_PROVIDER=openai               # openai | anthropic | disabled
LLM_MODEL_NAME=gpt-4o-mini
LLM_TEMPERATURE=0.1
LLM_MAX_TOKENS=1024
LLM_REQUEST_TIMEOUT_SECONDS=30
LLM_FALLBACK_CONFIDENCE_THRESHOLD=0.6

# Required if LLM_PROVIDER=openai
OPENAI_API_KEY=sk-your-openai-api-key

# Required if LLM_PROVIDER=anthropic
ANTHROPIC_API_KEY=sk-ant-your-anthropic-api-key

# ── Scoring ───────────────────────────────────────────────────────
SCORING_AUTO_EXECUTE_THRESHOLD=80
SCORING_MANUAL_REVIEW_THRESHOLD=60

# ── Risk Management ───────────────────────────────────────────────
RISK_DAILY_LOSS_LIMIT_USD=200.0
RISK_MAX_OPEN_POSITIONS=5
RISK_MAX_CRYPTO_EXPOSURE_USD=300.0
RISK_MAX_STOCK_EXPOSURE_USD=1500.0
RISK_CONSECUTIVE_LOSS_COOLDOWN_MINUTES=60
RISK_CONSECUTIVE_LOSSES_BEFORE_COOLDOWN=3
RISK_KILL_SWITCH_ACTIVE=false
RISK_MANUAL_PAUSE_ACTIVE=false
RISK_REQUIRE_STOP_LOSS=true
RISK_MAX_SPREAD_PCT=0.5

# ── Notifications ─────────────────────────────────────────────────
NOTIFY_TELEGRAM_ENABLED=false
NOTIFY_TELEGRAM_BOT_TOKEN=your-telegram-bot-token
NOTIFY_TELEGRAM_CHAT_ID=your-telegram-chat-id

NOTIFY_EMAIL_ENABLED=false
NOTIFY_EMAIL_SENDER=alerts@yourdomain.com
NOTIFY_EMAIL_RECIPIENT=you@yourdomain.com
NOTIFY_SMTP_HOST=smtp.sendgrid.net
NOTIFY_SMTP_PORT=587
NOTIFY_SMTP_USERNAME=apikey
NOTIFY_SMTP_PASSWORD=your-sendgrid-api-key

NOTIFY_SLACK_ENABLED=false
NOTIFY_SLACK_BOT_TOKEN=xoxb-your-slack-bot-token
NOTIFY_SLACK_CHANNEL_ID=C0XXXXXXXXX
